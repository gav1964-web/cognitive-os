{
  "schema_version": "capability_patterns.v1",
  "records": [
    {"record_type": "capability_pattern", "pattern_id": "parse_structured_text", "label": "parse structured text", "match": {"text_contains_any": ["parse", "parser", "deserialize", "decode"], "min_score": 2}, "contract_hint": "RawText/InputBytes -> ParsedObject | ParseFailure", "test_strategy": ["valid input", "malformed input", "empty input", "encoding edge case"], "first_slice_hint": "separate parsing from I/O and downstream decisions"},
    {"record_type": "capability_pattern", "pattern_id": "normalize_record", "label": "normalize record", "match": {"text_contains_any": ["normalize", "canonical", "standardize"]}, "contract_hint": "RawRecord -> NormalizedRecord", "test_strategy": ["missing field", "extra field", "canonical ordering"], "first_slice_hint": "make normalization pure and deterministic"},
    {"record_type": "capability_pattern", "pattern_id": "validate_schema", "label": "validate schema", "match": {"text_contains_any": ["validate", "schema", "pydantic", "jsonschema"]}, "contract_hint": "Payload -> ValidPayload | ValidationErrorList", "test_strategy": ["valid payload", "missing required field", "wrong type", "unknown field"], "first_slice_hint": "return structured validation findings instead of raising arbitrary errors"},
    {"record_type": "capability_pattern", "pattern_id": "build_cache_key", "label": "build cache key", "match": {"text_contains_any": ["build_key", "cache_key", "cache", "hash", "digest"], "min_score": 2}, "contract_hint": "StableInputs -> CacheKey", "test_strategy": ["same input same key", "different provider changes key", "field ordering stable"], "first_slice_hint": "keep key construction pure and include version/policy inputs"},
    {"record_type": "capability_pattern", "pattern_id": "request_envelope_builder", "label": "request envelope builder", "match": {"text_contains_any": ["request", "envelope", "headers", "payload"], "min_score": 2}, "contract_hint": "UserInput + Policy -> RequestEnvelope", "test_strategy": ["required headers", "redaction", "malformed input"], "first_slice_hint": "separate request construction from transport execution"},
    {"record_type": "capability_pattern", "pattern_id": "response_normalizer", "label": "response normalizer", "match": {"text_contains_any": ["response", "normalize_response", "parse_response"], "min_score": 2}, "contract_hint": "RawResponse -> NormalizedResponse | ProviderFailure", "test_strategy": ["happy response", "missing field", "provider error shape"], "first_slice_hint": "normalize provider-specific responses into one internal shape"},
    {"record_type": "capability_pattern", "pattern_id": "error_mapper", "label": "error mapper", "match": {"text_contains_any": ["error", "exception", "failure", "map_error"], "min_score": 4}, "contract_hint": "Exception/Failure -> StableErrorPacket", "test_strategy": ["known exception", "unknown exception", "sensitive message redaction"], "first_slice_hint": "turn exceptions into stable taxonomy before retry/review"},
    {"record_type": "capability_pattern", "pattern_id": "retry_policy", "label": "retry policy", "match": {"text_contains_any": ["retry", "backoff", "transient"]}, "contract_hint": "Failure + AttemptState -> RetryDecision", "test_strategy": ["transient retry", "permanent stop", "max attempts"], "first_slice_hint": "make retry decision pure and bounded"},
    {"record_type": "capability_pattern", "pattern_id": "rate_limit_policy", "label": "rate limit policy", "match": {"text_contains_any": ["rate limit", "quota", "throttle"]}, "contract_hint": "RequestIdentity + WindowState -> RateLimitDecision", "test_strategy": ["under quota", "over quota", "window rollover"], "first_slice_hint": "separate quota state from transport calls"},
    {"record_type": "capability_pattern", "pattern_id": "timeout_wrapper", "label": "timeout wrapper", "match": {"text_contains_any": ["timeout", "deadline", "cancel"]}, "contract_hint": "Operation + Deadline -> Result | TimeoutFailure", "test_strategy": ["fast success", "timeout", "cancelled operation"], "first_slice_hint": "represent timeout as controlled failure packet"},
    {"record_type": "capability_pattern", "pattern_id": "checkpoint_writer", "label": "checkpoint writer", "match": {"text_contains_any": ["checkpoint", "progress", "resume"]}, "contract_hint": "ProgressSnapshot -> CheckpointRef", "test_strategy": ["write checkpoint", "read checkpoint", "corrupt checkpoint"], "first_slice_hint": "persist enough state to resume without repeating side effects"},
    {"record_type": "capability_pattern", "pattern_id": "artifact_manifest", "label": "artifact manifest", "match": {"text_contains_any": ["manifest", "artifact", "output files"], "min_score": 2}, "contract_hint": "ProducedArtifacts -> ArtifactManifest", "test_strategy": ["file exists", "checksum mismatch", "missing artifact"], "first_slice_hint": "record outputs as data, not only filesystem side effects"},
    {"record_type": "capability_pattern", "pattern_id": "file_discovery", "label": "file discovery", "match": {"text_contains_any": ["scan", "discover", "glob", "walk"]}, "contract_hint": "Root + Filters -> FileSet", "test_strategy": ["ignore dirs", "symlink/noise", "empty tree"], "first_slice_hint": "make traversal deterministic and scoped"},
    {"record_type": "capability_pattern", "pattern_id": "batch_processor", "label": "batch processor", "match": {"text_contains_any": ["batch", "chunk", "page", "paginate"]}, "contract_hint": "BatchInput + Cursor -> BatchResult + NextCursor", "test_strategy": ["first page", "last page", "partial failure"], "first_slice_hint": "record cursor/progress and isolate per-item failures"},
    {"record_type": "capability_pattern", "pattern_id": "csv_table_transform", "label": "CSV/table transform", "match": {"text_contains_any": ["csv", "table", "dataframe", "rows"], "min_score": 2}, "contract_hint": "TabularInput -> TabularOutput", "test_strategy": ["missing column", "extra column", "empty file"], "first_slice_hint": "separate schema validation from row transformation"},
    {"record_type": "capability_pattern", "pattern_id": "html_fetch_parse", "label": "HTML fetch/parse", "match": {"text_contains_any": ["html", "scrape", "crawler", "beautifulsoup"]}, "contract_hint": "UrlFetchResult -> ParsedHtmlItems", "test_strategy": ["captured HTML", "layout drift", "empty result"], "first_slice_hint": "test parser with captured HTML, not live site"},
    {"record_type": "capability_pattern", "pattern_id": "token_session_refresh", "label": "token/session refresh", "match": {"text_contains_any": ["token", "refresh", "session", "oauth"], "min_score": 2}, "contract_hint": "AuthState -> RefreshedAuthState | AuthFailure", "test_strategy": ["expired token", "invalid refresh", "redaction"], "first_slice_hint": "separate token decision from network refresh call"},
    {"record_type": "capability_pattern", "pattern_id": "permission_decision", "label": "permission decision", "match": {"text_contains_any": ["permission", "authorize", "policy"]}, "contract_hint": "Principal + Action + Resource -> AuthDecision", "test_strategy": ["allow", "deny", "unknown principal"], "first_slice_hint": "make deny result explicit and testable"},
    {"record_type": "capability_pattern", "pattern_id": "template_render", "label": "template render", "match": {"text_contains_any": ["template", "render", "jinja"]}, "contract_hint": "TemplateSource + Context -> RenderResult", "test_strategy": ["missing variable", "escaping", "stable output"], "first_slice_hint": "separate loading, context validation, and rendering"},
    {"record_type": "capability_pattern", "pattern_id": "metric_export", "label": "metric export", "match": {"text_contains_any": ["metric", "telemetry", "export", "span"]}, "contract_hint": "TelemetryEvent -> ExportResult", "test_strategy": ["redaction", "export failure", "cardinality guard"], "first_slice_hint": "exporter failure must degrade without breaking primary flow"},
    {"record_type": "capability_pattern", "pattern_id": "array_compute", "label": "array compute", "match": {"text_contains_any": ["array", "tensor", "matrix", "solver"], "min_score": 2}, "contract_hint": "ArrayInput -> ComputeResult", "test_strategy": ["bad shape", "nan policy", "tolerance"], "first_slice_hint": "declare shape/dtype/tolerance explicitly"},
    {"record_type": "capability_pattern", "pattern_id": "plugin_registry_lookup", "label": "plugin registry lookup", "match": {"text_contains_any": ["registry", "capability", "plugin"], "min_score": 2}, "contract_hint": "CapabilityRequest -> CapabilityDescriptor | MissingCapability", "test_strategy": ["active plugin", "degraded plugin", "missing plugin"], "first_slice_hint": "selection policy must be deterministic and explainable"},
    {"record_type": "capability_pattern", "pattern_id": "config_loader", "label": "config loader", "match": {"text_contains_any": ["config", "settings", "env"], "min_score": 2}, "contract_hint": "ConfigSources -> EffectiveConfig | ConfigError", "test_strategy": ["missing config", "env override", "secret redaction"], "first_slice_hint": "separate discovery, parsing, and validation"},
    {"record_type": "capability_pattern", "pattern_id": "subprocess_runner", "label": "subprocess runner", "match": {"text_contains_any": ["subprocess", "process", "command"], "min_score": 2}, "contract_hint": "CommandSpec -> ProcessResult | ProcessFailure", "test_strategy": ["success", "nonzero exit", "timeout"], "first_slice_hint": "wrap process execution with timeout and captured logs"},
    {"record_type": "capability_pattern", "pattern_id": "queue_enqueue", "label": "queue enqueue", "match": {"text_contains_any": ["enqueue", "queue", "job"], "min_score": 2}, "contract_hint": "JobRequest -> JobReceipt", "test_strategy": ["enqueue", "duplicate id", "queue unavailable"], "first_slice_hint": "define job identity and idempotency key"},
    {"record_type": "capability_pattern", "pattern_id": "queue_worker_execute", "label": "queue worker execute", "match": {"text_contains_any": ["worker", "perform_job", "ack", "nack", "job lease", "poison job"], "required_contains_any": ["queue", "job", "worker"], "min_score": 2}, "contract_hint": "JobLease -> JobResult | RetryDecision", "test_strategy": ["success ack", "retryable failure", "poison job"], "first_slice_hint": "separate lease/ack policy from job logic"},
    {"record_type": "capability_pattern", "pattern_id": "db_query_unit", "label": "database query unit", "match": {"text_contains_any": ["query", "session", "select", "transaction"], "min_score": 2}, "contract_hint": "QueryInput -> QueryRows | DbFailure", "test_strategy": ["empty result", "bad filter", "transaction failure"], "first_slice_hint": "separate query shape from connection/session ownership"},
    {"record_type": "capability_pattern", "pattern_id": "db_write_unit", "label": "database write unit", "match": {"text_contains_any": ["insert", "update", "commit", "flush"], "min_score": 2}, "contract_hint": "WriteCommand -> WriteResult | Conflict", "test_strategy": ["insert", "duplicate", "rollback"], "first_slice_hint": "make transaction boundary and idempotency explicit"},
    {"record_type": "capability_pattern", "pattern_id": "report_generator", "label": "report generator", "match": {"text_contains_any": ["report", "markdown", "summary"], "min_score": 2}, "contract_hint": "AnalysisFacts -> ReportArtifact", "test_strategy": ["missing fields", "stable sections", "redaction"], "first_slice_hint": "keep report rendering separate from analysis decisions"},
    {"record_type": "capability_pattern", "pattern_id": "diff_patch_builder", "label": "diff/patch builder", "match": {"text_contains_any": ["unified diff", "patch package", "apply_patch", "patch scope"]}, "contract_hint": "ChangePlan -> PatchPackage", "test_strategy": ["clean apply", "conflict", "forbidden path"], "first_slice_hint": "validate patch scope before touching source"},
    {"record_type": "capability_pattern", "pattern_id": "secret_redactor", "label": "secret redactor", "match": {"text_contains_any": ["secret", "redact", "token", "password"], "min_score": 2}, "contract_hint": "TextOrArtifact -> RedactedArtifact + Findings", "test_strategy": ["token", "password", "false positive"], "first_slice_hint": "redaction policy must run before logs/reports are persisted"},
    {"record_type": "capability_pattern", "pattern_id": "schema_mapper", "label": "schema mapper", "match": {"text_contains_any": ["mapper", "mapping", "schema", "model"], "min_score": 2}, "contract_hint": "SourceModel -> TargetModel | MappingError", "test_strategy": ["known mapping", "missing field", "unknown enum"], "first_slice_hint": "make mapping table explicit and versioned"},
    {"record_type": "capability_pattern", "pattern_id": "fallback_selector", "label": "fallback selector", "match": {"text_contains_any": ["fallback", "alternative", "degrade"]}, "contract_hint": "FailureContext + Options -> FallbackDecision", "test_strategy": ["fallback available", "fallback forbidden", "stop"], "first_slice_hint": "fallback decision belongs outside the failing adapter"},
    {"record_type": "capability_pattern", "pattern_id": "feature_flag_decision", "label": "feature flag decision", "match": {"text_contains_any": ["feature flag", "toggle", "enabled"]}, "contract_hint": "Actor + Flag + Context -> FlagDecision", "test_strategy": ["enabled", "disabled", "missing flag"], "first_slice_hint": "keep flag lookup and business decision separate"},
    {"record_type": "capability_pattern", "pattern_id": "data_lifecycle_tracker", "label": "data lifecycle tracker", "match": {"text_contains_any": ["raw", "parsed", "normalized", "lifecycle"]}, "contract_hint": "PipelineStepFacts -> DataLifecycleMap", "test_strategy": ["single step", "branching step", "missing artifact"], "first_slice_hint": "record shape transitions from input to output"},
    {"record_type": "capability_pattern", "pattern_id": "cli_argument_contract", "label": "CLI argument contract", "match": {"text_contains_any": ["argparse", "click", "typer", "command line", "cli"], "min_score": 2}, "contract_hint": "Argv + Environment -> CommandRequest | UsageError", "test_strategy": ["valid args", "missing required arg", "invalid path", "help output"], "first_slice_hint": "implement parser and validation before business logic"},
    {"record_type": "capability_pattern", "pattern_id": "file_format_converter", "label": "file format converter", "match": {"text_contains_any": ["convert", "converter", "input file", "output file", "format"], "min_score": 2}, "contract_hint": "InputArtifact + ConversionOptions -> OutputArtifact | ConversionFailure", "test_strategy": ["happy conversion", "unsupported extension", "corrupt input", "output overwrite policy"], "first_slice_hint": "separate read, transform, and write stages"},
    {"record_type": "capability_pattern", "pattern_id": "image_input_pipeline", "label": "image input pipeline", "match": {"text_contains_any": ["image", "picture", "ocr", "vision", "pillow", "opencv"], "min_score": 2}, "contract_hint": "ImagePath + RecognitionPolicy -> ImageObservation | ImageReadFailure", "test_strategy": ["valid image", "missing file", "unsupported format", "model unavailable"], "first_slice_hint": "keep image loading/preprocessing separate from recognition provider calls"},
    {"record_type": "capability_pattern", "pattern_id": "provider_adapter_boundary", "label": "provider adapter boundary", "match": {"text_contains_any": ["provider", "adapter", "client", "api key", "model"], "min_score": 2}, "contract_hint": "ProviderRequest -> ProviderResult | ProviderFailure", "test_strategy": ["fake provider success", "timeout", "auth failure", "malformed provider response"], "first_slice_hint": "write fake-provider tests before live integration"},
    {"record_type": "capability_pattern", "pattern_id": "small_project_scaffold", "label": "small project scaffold", "match": {"text_contains_any": ["create project", "write cli", "package", "readme", "tests"], "min_score": 2}, "contract_hint": "GoalSpec -> ProjectScaffold + RunInstructions", "test_strategy": ["files created", "entrypoint runs", "tests pass", "README command matches"], "first_slice_hint": "generate minimal runnable package before adding optional features"},
    {"record_type": "capability_pattern", "pattern_id": "acceptance_test_mapper", "label": "acceptance test mapper", "match": {"text_contains_any": ["acceptance", "success criteria", "expected output", "verify"], "min_score": 2}, "contract_hint": "Requirements -> AcceptanceTestSet", "test_strategy": ["one test per requirement", "negative case", "artifact check"], "first_slice_hint": "map every user-visible requirement to at least one executable check"}
  ]
}
