{
  "schema_version": "role_artifact_pipeline.v1",
  "steps": [
    {
      "step_id": "architecture_decision",
      "role_id": "architect",
      "builder": "runtime.role_architect:run_architect_skill",
      "output_key": "architecture_decision",
      "bindings": {
        "goal": "$goal",
        "project_report": "$project_report",
        "advisory_config": "$architect_advisory_config"
      }
    },
    {
      "step_id": "technical_spec",
      "role_id": "spec_writer",
      "builder": "runtime.role_spec_writer:run_spec_writer_skill",
      "output_key": "technical_spec",
      "bindings": {
        "architecture_decision": "$artifacts.architecture_decision"
      }
    },
    {
      "step_id": "implementation_plan",
      "role_id": "implementer",
      "builder": "runtime.role_implementer:run_implementer_skill",
      "output_key": "implementation_plan",
      "bindings": {
        "technical_spec": "$artifacts.technical_spec"
      }
    },
    {
      "step_id": "test_plan",
      "role_id": "tester",
      "builder": "runtime.role_tester:run_tester_skill",
      "output_key": "test_plan",
      "bindings": {
        "technical_spec": "$artifacts.technical_spec",
        "implementation_plan": "$artifacts.implementation_plan"
      }
    },
    {
      "step_id": "review_findings",
      "role_id": "reviewer",
      "builder": "runtime.role_reviewer:run_reviewer_skill",
      "output_key": "review_findings",
      "bindings": {
        "technical_spec": "$artifacts.technical_spec",
        "implementation_plan": "$artifacts.implementation_plan",
        "test_plan": "$artifacts.test_plan",
        "test_result": "$test_result"
      }
    }
  ]
}
