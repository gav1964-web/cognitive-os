      "role_id": "implementer"
    },
    "test_plan_v1": {
      "callable": "runtime.role_tester:run_tester_skill",
      "artifact_type": "TestPlan",
      "role_id": "tester"
    },
    "review_findings_v1": {
      "callable": "runtime.role_reviewer:run_reviewer_skill",
      "artifact_type": "ReviewFindings",
      "role_id": "reviewer"
    }
