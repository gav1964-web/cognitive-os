      "role_id": "architect"
    },
    "technical_spec_v1": {
      "callable": "runtime.role_spec_writer:run_spec_writer_skill",
      "artifact_type": "TechnicalSpec",
      "role_id": "spec_writer"
    },
    "implementation_plan_v1": {
      "callable": "runtime.role_implementer:run_implementer_skill",
