{
  "id": "translate_text",
  "purpose": "Translate short text to a supported target language using a deterministic MVP dictionary.",
  "input_contract": {
    "text": "string",
    "target_language": "string"
  },
  "output_contract": {
    "text": "string",
    "language": "string"
  },
  "error_policy": {
    "missing_text": "raise KeyError",
    "missing_target_language": "raise KeyError",
    "unsupported_language": "raise ValueError"
  },
  "side_effects": {
    "filesystem": "none",
    "network": "none",
    "secrets": "none"
  },
  "quality_gate": {
      "sample_input": {
        "text": "hello",
        "target_language": "German"
      },
      "expected_output": {
        "text": "hallo",
        "language": "German"
      }
  },
  "reusable": true
}
